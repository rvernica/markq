#!/usr/bin/env bash
# Verify staged Rust code is rustfmt-clean. Fails (does not auto-fix) so the
# commit reflects exactly what was reviewed. Run `cargo fmt --all` and re-stage
# to fix.
#
# Checks the *staged blob content* of each .rs file (not the working tree), so
# unstaged drift elsewhere won't make the hook fail, and staged-but-modified
# files are checked as they will appear in the commit.
set -euo pipefail

# Friendly error if the toolchain isn't on PATH (common when committing from a
# GUI whose environment doesn't inherit rustup's shims).
if ! command -v rustfmt >/dev/null 2>&1; then
    echo "pre-commit: rustfmt not found on PATH." >&2
    echo "Install via rustup (https://rustup.rs) or skip this hook with --no-verify." >&2
    exit 1
fi

# Collect staged .rs paths into an array. `|| true` so an empty match (no .rs
# files staged) doesn't trip `set -e` via grep's exit code. We deliberately
# don't use `-z` here: the script can't handle embedded newlines in paths
# anyway (the `for f in "${staged[@]}"` loop assumes newline-delimited), and
# pretending otherwise was misleading.
mapfile -t staged < <(
    git diff --cached --name-only --diff-filter=ACMR \
        | grep -E '\.rs$' || true
)

if [[ ${#staged[@]} -eq 0 ]]; then
    exit 0
fi

# Derive the edition from the workspace Cargo.toml so an edition bump (2021 ->
# 2024) doesn't silently desync from `cargo fmt`. Falls back to 2021 if the
# field isn't found.
#
# Notes on portability/correctness:
# - `[[:space:]]` instead of `\s` so BSD grep on macOS (in-scope for Metal
#   builds) doesn't take the regex literally and silently fall back.
# - Anchor the path to the worktree root so the hook works regardless of
#   the cwd it was invoked from.
# - Read only the `[workspace.package]` section to avoid picking up a
#   stray per-crate `edition = "..."` that might land above it later.
root="$(git rev-parse --show-toplevel)"
edition="$(
    awk '
        /^\[workspace\.package\]/ { in_section = 1; next }
        /^\[/                     { in_section = 0 }
        in_section && /^edition[[:space:]]*=/ {
            match($0, /"[^"]+"/)
            if (RSTART > 0) {
                print substr($0, RSTART + 1, RLENGTH - 2)
                exit
            }
        }
    ' "$root/Cargo.toml" 2>/dev/null || true
)"
edition="${edition:-2021}"

fail=0
for f in "${staged[@]}"; do
    # Feed the *staged blob* (index version) to rustfmt --check, not the
    # working-tree file. `git show :<path>` reads the index entry directly.
    # Capture output so we can print the offending diff with a per-file
    # header on failure (rustfmt --check writes the diff to stdout).
    if ! output="$(git show ":$f" | rustfmt --check --edition "$edition" 2>&1)"; then
        echo "pre-commit: rustfmt check failed for $f" >&2
        if [[ -n $output ]]; then
            printf '%s\n' "$output" >&2
        fi
        fail=1
    fi
done

if [[ $fail -ne 0 ]]; then
    echo >&2
    echo "Run 'cargo fmt --all' and re-stage the affected files." >&2
    exit 1
fi
